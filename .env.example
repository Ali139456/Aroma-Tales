# Copy to `.env` locally. Never commit a real `.env` with secrets.

# Supabase (Dashboard → Settings → API): Project URL + anon public key.
# Admin CRM uses Supabase Auth + RLS (see supabase/schema.sql).
# Auth → URL configuration: add every origin you use + /auth and /admin/login, e.g.
#   https://yourdomain.com/auth   http://localhost:5173/auth   (Vite default port)
# Signup uses emailRedirectTo from the live page origin so confirmation links return to the right host.
VITE_SUPABASE_URL=https://nnaeamtgjlaazgzthixq.supabase.co
VITE_SUPABASE_ANON_KEY=

# Resend is used only by the Supabase Edge Function `supabase/functions/notify-new-order`.
# Do NOT add RESEND_API_KEY as VITE_* (it would ship to the browser). Set on Supabase instead:
#   supabase secrets set RESEND_API_KEY=re_xxx ORDER_NOTIFY_SECRET=long-random-string
# Optional:
#   RESEND_FROM="Aroma Tales <orders@your-verified-domain>"
#   SHOP_NOTIFY_EMAIL=you@example.com
#   STORE_URL=https://yourdomain.shop   (links in customer emails)
# Webhooks (same URL + Authorization: Bearer <ORDER_NOTIFY_SECRET>):
#   INSERT on orders → shop new-order + customer confirmation
#   UPDATE on orders → customer status / delivery updates (and draft→pending → shop + customer)
# Vercel: no Resend env vars for this app unless you add server-side mail there.
